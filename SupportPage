// ===== ГЛАВНЫЙ КОМПОНЕНТ =====
export default function SupportPage() {
  const [openId, setOpenId] = useState(null);
  const [page, setPage] = useState(1);
  const [search, setSearch] = useState("");

  // TODO: при большом кол-ве данных — поиск на бекенде: GET /api/support/search?q=...
  const filtered = CATEGORIES.filter(c =>
    c.title.toLowerCase().includes(search.toLowerCase())
  );

  const toggle = (id) => setOpenId(prev => prev === id ? null : id);

  return (
    <>
      <style>{css}</style>
      <Navbar />
      <main className="page">
        <h1 className="page-title">Support</h1>

        <div className="search-wrap">
          <input
            className="search-input"
            placeholder="Find help"
            value={search}
            onChange={e => { setSearch(e.target.value); setOpenId(null); }}
          />
        </div>

        <div className="accordion-list">
          {filtered.length > 0
            ? filtered.map(item => (
                <AccordionItem
                  key={item.id}
                  item={item}
                  isOpen={openId === item.id}
                  onToggle={() => toggle(item.id)}
                />
              ))
            : <p style={{ color: "#8f98a0", fontSize: 14 }}>Nothing found</p>
          }
        </div>

        {/* TODO: передавать реальное кол-во страниц с API */}
        <Pagination current={page} onChange={setPage} />

        <div className="cta-block">
          <h2 className="cta-title">Have any other questions?</h2>
          {/* TODO: повесить ссылку на email или форму */}
          <button className="cta-btn">Contact us on our email!</button>
        </div>
      </main>
      <Footer />
    </>
  );
}
