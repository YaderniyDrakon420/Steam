// ===== АККОРДЕОН — анимация через useRef =====
function AccordionItem({ item, isOpen, onToggle }) {
  const bodyRef = useRef(null);

  // каждый раз когда isOpen меняется — ставим реальную высоту
  useEffect(() => {
    const el = bodyRef.current;
    if (!el) return;

    if (isOpen) {
      // ставим высоту содержимого — браузер плавно анимирует
      el.style.height = el.scrollHeight + "px";
    } else {
      // сначала фиксируем текущую высоту, потом сбрасываем в 0
      el.style.height = el.scrollHeight + "px";
      requestAnimationFrame(() => {
        el.style.height = "0px";
      });
    }
  }, [isOpen]);

  return (
    <div className="accordion-item">
      <div className="accordion-header" onClick={onToggle}>
        <span className="accordion-title">{item.title}</span>
        <span className={`accordion-arrow ${isOpen ? "open" : ""}`}>›</span>
      </div>

      {/* ref на обёртку — по ней считаем высоту */}
      <div ref={bodyRef} className={`accordion-body ${isOpen ? "open" : ""}`}>
        <div className="accordion-body-inner">{item.body}</div>
      </div>
    </div>
  );
}

function Pagination({ current, onChange }) {
  const pages = [1, 2, 3, 4, 5, 6];
  return (
    <div className="pagination">
      <button className="page-btn" disabled={current === 1} onClick={() => onChange(current - 1)}>‹ Previous</button>
      {pages.map(p => (
        <button key={p} className={`page-btn ${current === p ? "active" : ""}`} onClick={() => onChange(p)}>{p}</button>
      ))}
      <span className="page-btn" style={{ cursor: "default" }}>...</span>
      <button className="page-btn" onClick={() => onChange(198)}>198</button>
      <button className="page-btn" onClick={() => onChange(Math.min(current + 1, 198))}>Next ›</button>
    </div>
  );
}

