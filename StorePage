// строка в списке (Top Sellers / Most Played / Upcoming)
function ListItem({ num, game }) {
  if (!game) return (
    <div className="list-item">
      <span className="list-num">{num}</span>
      <div className="list-thumb skeleton" style={{ width: 40, height: 40 }} />
      <div className="list-info">
        <div className="skeleton" style={{ height: 12, width: "70%", marginBottom: 4 }} />
        <div className="skeleton" style={{ height: 10, width: "40%" }} />
      </div>
    </div>
  );
  const isFree = game.price === 0 || game.price === "Free";
  return (
    <div className="list-item">
      <span className="list-num">{num}</span>
      <div className="list-thumb" style={game.coverUrl ? { backgroundImage: `url(${game.coverUrl})` } : {}} />
      <div className="list-info">
        <div className="list-name">{game.title}</div>
        <div className={`list-price ${isFree ? "free" : ""}`}>
          {isFree ? "Free" : `$${game.price}`}
        </div>
      </div>
    </div>
  );
}

