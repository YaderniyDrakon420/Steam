// пустая карточка — пока нет данных из API
function EmptyCard({ aspect = "3/4" }) {
  return (
    <div className="empty-card" style={{ aspectRatio: aspect }}>
      <span className="empty-card-icon">🎮</span>
      <span>No data yet</span>
    </div>
  );
}

// вертикальная карточка игры
// props: { title, coverUrl, price, discountPct, oldPrice }
// всё это придёт из Games таблицы
function GameCard({ game }) {
  if (!game) return <EmptyCard aspect="3/4" />;

  const hasDiscount = game.discountPct > 0;
  const isFree = game.price === 0 || game.price === "Free";

  return (
    <div className="game-card">
      {/* Games.CoverImageUrl */}
      <div
        className="game-thumb"
        style={game.coverUrl ? { backgroundImage: `url(${game.coverUrl})`, backgroundSize: "cover" } : {}}
      >
        {!game.coverUrl && "No cover"}
      </div>
      <div className="game-info">
        {/* Games.Title */}
        <div className="game-name">{game.title}</div>
        {/* Games.Price + DiscountPercentage */}
        {isFree ? (
          <div className="game-price free">Free</div>
        ) : hasDiscount ? (
          <div className="price-row">
            <span className="price-badge">-{game.discountPct}%</span>
            <span className="price-old">${game.oldPrice}</span>
            <span className="price-new">${game.price}</span>
          </div>
        ) : (
          <div className="game-price">${game.price}</div>
        )}
      </div>
    </div>
  );
}

// горизонтальная карточка (sale spotlight)
function SaleCard({ game }) {
  if (!game) return <EmptyCard aspect="16/9" />;
  const hasDiscount = game.discountPct > 0;
  return (
    <div className="sale-card">
      <div className="sale-thumb" style={game.coverUrl ? { backgroundImage: `url(${game.coverUrl})` } : {}} />
      <div className="sale-info">
        <div className="sale-name">{game.title}</div>
        {hasDiscount ? (
          <div className="price-row">
            <span className="price-badge">-{game.discountPct}%</span>
            <span className="price-old">${game.oldPrice}</span>
            <span className="price-new">${game.price}</span>
          </div>
        ) : (
          <div className="game-price">${game.price}</div>
        )}
      </div>
    </div>
  );
}

