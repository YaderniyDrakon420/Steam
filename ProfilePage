function GameCard({ game }) {
  return (
    <div className="game-card">
      {/* если есть coverUrl — показываем картинку, иначе цветной блок с названием */}
      {game.coverUrl
        ? <img className="game-cover" src={game.coverUrl} alt={game.title} />
        : (
          <div className="game-cover-placeholder" style={{ background: game.coverColor }}>
            {game.title}
          </div>
        )
      }
      <div className="game-info">
        <div className="game-title">{game.title}</div>
        <div className="game-meta-row">
          <div className="game-icons">
            {game.icons.map((ico, i) => (
              <div key={i} className="game-icon">{ico}</div>
            ))}
          </div>
          <div className="game-hours">
            {game.playTime}h played on record<br />
            Last played: {game.lastPlayed}
          </div>
        </div>
        <div className="progress-label">Completed: {game.completedPct}%</div>
        <div className="progress-bar">
          <div
            className={`progress-fill ${game.completedPct === 100 ? "full" : ""}`}
