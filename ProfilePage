// ===== МОДАЛКА РЕДАКТИРОВАНИЯ =====
function EditModal({ user, onSave, onClose }) {
  const [nickname, setNickname] = useState(user.nickname);

  return (
    <div className="modal-bg" onClick={onClose}>
      <div className="modal" onClick={e => e.stopPropagation()}>
        <h3>Edit profile</h3>

        <label className="modal-label">Nickname</label>
        <input
          className="modal-input"
          value={nickname}
          onChange={e => setNickname(e.target.value)}
        />

        <label className="modal-label">Email (read only)</label>
        <input className="modal-input" value={user.email} disabled />

        <div className="modal-btns">
          <button className="btn-cancel" onClick={onClose}>Cancel</button>
          <button className="btn-green" onClick={() => onSave({ nickname })}>Save</button>
        </div>
      </div>
    </div>
  );
}

// ===== ШАПКА ПРОФИЛЯ =====
function ProfileHeader({ user, onUpdate }) {
  const [showEdit, setShowEdit] = useState(false);
  const fileRef = useRef(null);

  const handleAvatar = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    // показываем превью сразу, потом бекендер загрузит на сервер
    const localUrl = URL.createObjectURL(file);
    onUpdate({ avatarUrl: localUrl });
  };

  return (
    <>
      <div className="profile-header">
        <div className="online-badge">
          <div className="online-dot" /> Online
        </div>

        {/* аватарка — клик открывает выбор файла */}
        <div className="avatar-wrap" onClick={() => fileRef.current.click()}>
          <div className="avatar">
            {user.avatarUrl ? <img src={user.avatarUrl} alt="avatar" /> : "👤"}
          </div>
          <div className="avatar-overlay">Change<br/>photo</div>
          <input
            ref={fileRef}
            type="file"
            accept="image/*"
            style={{ display: "none" }}
            onChange={handleAvatar}
          />
        </div>

        <div className="profile-info">
          <div className="profile-level">Level <span>{user.level}</span></div>
          <div className="profile-name">{user.nickname}</div>
          <div className="profile-email">{user.email}</div>
          <div className="profile-stats">
            <div>
              <div className="stat-num">{user.gamesCount}</div>
              <div className="stat-label">Games</div>
            </div>
            <div>
              <div className="stat-num">{user.achievementsCount}</div>
              <div className="stat-label">Achievements</div>
            </div>
            <div>
              <div className="stat-num" style={{ fontSize: 14 }}>
                {new Date(user.createdAt).getFullYear()}
              </div>
              <div className="stat-label">Member since</div>
            </div>
          </div>
        </div>

        {/* баланс */}
        <div className="balance-chip">$ {Number(user.balance).toFixed(2)}</div>
        <button className="edit-btn" onClick={() => setShowEdit(true)}>Edit profile</button>
      </div>

      {showEdit && (
        <EditModal
          user={user}
          onSave={(data) => { onUpdate(data); setShowEdit(false); }}
          onClose={() => setShowEdit(false)}
        />
      )}
    </>
  );
}

